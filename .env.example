# Application
APP_NAME=python-toolkit
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Kafka (external broker)
KAFKA_BOOTSTRAP_SERVERS=<host>:9092
KAFKA_CONSUMER_GROUP_ID=python-toolkit-group
KAFKA_AUDIT_TOPIC=audit.requests
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# Database Backend Selection
DB_BACKEND=postgres  # postgres | mongodb | redis

# PostgreSQL (primary database)
POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/python_toolkit

# MongoDB (alternative NoSQL database)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=python_toolkit

# Redis (caching and sessions only)
REDIS_URL=redis://<host>:6379/0
REDIS_CACHE_TTL=3600

# Gemini (Google AI)
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-1.5-pro
GEMINI_TIMEOUT_SECONDS=60

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_TIMEOUT_SECONDS=60
